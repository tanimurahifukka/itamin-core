{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "regions": ["hnd1"],
  "functions": {
    "api/index.ts": {
      "includeFiles": "backend/src/**",
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/check/templates/(.*)",
      "destination": "/api"
    },
    {
      "source": "/api/check/shift-map/(.*)",
      "destination": "/api"
    },
    {
      "source": "/api/check/checklists/(.*)",
      "destination": "/api"
    },
    {
      "source": "/api/check/records/(.*)",
      "destination": "/api"
    },
    {
      "source": "/api/check/(.*)",
      "destination": "https://itamin-check.vercel.app/api/check/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "framework": "vite",
  "crons": [
    {
      "path": "/api/cron/switchbot-readings",
      "schedule": "0 9 * * *"
    }
  ]
}
