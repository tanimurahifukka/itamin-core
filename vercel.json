{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "regions": ["hnd1"],
  "functions": {
    "api/index.ts": {
      "includeFiles": "backend/src/**",
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/check/(.*)",
      "destination": "https://itamin-check.vercel.app/api/check/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "framework": "vite"
}
